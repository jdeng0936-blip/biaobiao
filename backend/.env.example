# ============================================
# 标标 AI — 环境变量模板
# 复制为 .env 后填入真实值
# cp .env.example .env
# ============================================

# ---- 数据库 (PostgreSQL + pgvector) ----
DATABASE_URL=postgresql+asyncpg://biaobiao:biaobiao123@localhost:5434/biaobiao
DATABASE_URL_SYNC=postgresql://biaobiao:biaobiao123@localhost:5434/biaobiao

# ---- Redis ----
REDIS_URL=redis://localhost:6380/0

# ---- JWT 密钥（生产环境务必更换！）----
JWT_SECRET_KEY=biaobiao-ai-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- LLM API Keys ----
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---- LangFuse (可选：链路追踪) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- OSS / S3 (可选：对象存储) ----
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=

# ---- Docker Compose 端口映射 ----
PG_PORT=5434
REDIS_PORT=6380
API_PORT=8001
FE_PORT=3001

# ---- PostgreSQL (Docker Compose) ----
PG_USER=biaobiao
PG_PASSWORD=biaobiao123
PG_DB=biaobiao
